<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/dlTrash"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.trash.TrashActivity"
    tools:openDrawer="start">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/backgroundColor">

        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/ablTrash"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/tbTrash"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/primaryColor"
                android:theme="@style/MyThemeOverlay_Toolbar"
                app:navigationIcon="@drawable/ic_menu"
                app:title="@string/trash_title"
                app:titleTextColor="@color/white"
                tools:menu="@menu/trash_appbar" />
        </com.google.android.material.appbar.AppBarLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvTrash"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginBottom="@dimen/_35sdp"
            android:clipToPadding="false"
            android:padding="@dimen/_5sdp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/ablTrash"
            tools:itemCount="4"
            tools:listitem="@layout/item_note" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.navigation.NavigationView
        android:layout_width="@dimen/_235sdp"
        android:layout_height="match_parent"
        android:id="@+id/navTrash"
        app:drawerLayoutCornerSize="0dp"
        android:layout_marginTop="24dp"
        android:layout_gravity="start"
        android:fitsSystemWindows="true"
        app:dividerInsetStart="0dp"
        app:dividerInsetEnd="0dp"
        app:itemShapeInsetStart="0dp"
        app:itemShapeInsetEnd="0dp"
        app:itemShapeAppearance="@null"
        android:background="@color/backgroundColor"
        app:menu="@menu/menu_drawer"
        app:headerLayout="@layout/nav_header"/>

</androidx.drawerlayout.widget.DrawerLayout>

